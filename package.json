{
  "name": "personal-ai-architecture",
  "version": "0.1.0",
  "description": "Level 1 Foundation — Personal AI Architecture. Generic, user-owned AI runtime.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "personal-ai": "./dist/cli.js"
  },
  "scripts": {
    "generate:types": "tsx scripts/generate-types.ts",
    "build": "npm run generate:types && tsc",
    "pretest": "npm run generate:types",
    "test": "vitest run --reporter=verbose",
    "test:conformance": "vitest run test/conformance/ --reporter=verbose",
    "lint": "eslint src/",
    "check:imports": "tsx scripts/check-imports.ts",
    "check:lockin": "tsx scripts/check-lockin.ts",
    "baseline": "npm run build && vitest run --reporter=verbose && eslint src/ && npm run check:imports && npm run check:lockin"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "better-sqlite3": "^11.7.0",
    "hono": "^4.7.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "fast-check": "^3.23.0",
    "json-schema-to-typescript": "^15.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
